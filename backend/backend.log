        AND r.status IN ('PENDING', 'CONFIRMED')         
        AND r.arrival_date < ?         
        AND r.departure_date > ?   )  
HAVING
    ? IS NOT NULL     
    OR ? IS NULL     
    OR distance_km <= ?  
